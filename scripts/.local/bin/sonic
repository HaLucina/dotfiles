#!/bin/bash

ENV_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/env"
ENV_FILE="$ENV_DIR/BTearphones.env"
DEVICE_NAME="SOUNDPEATS Sonic"

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [ ! -s "$ENV_FILE" ]; then
    printf "${YELLOW}[System]${NC} Generating $ENV_FILE...\n"
    mkdir -p "$ENV_DIR" && chmod 700 "$ENV_DIR"
    
    MAC=$(bluetoothctl devices | grep "$DEVICE_NAME" | awk '{print $2}')
    
    if [ -n "$MAC" ]; then
        echo "MY_EARPHONE_MAC=\"$MAC\"" > "$ENV_FILE" && chmod 600 "$ENV_FILE"
        printf "${GREEN}[Success]${NC} Registered $MAC\n"
    else
        printf "${RED}[Error]${NC} $DEVICE_NAME not found.\n" >&2
        exit 1
    fi
fi

MAC_ADDRESS=$(grep '^MY_EARPHONE_MAC=' "$ENV_FILE" | cut -d '"' -f 2)

printf "${GREEN}󰂯${NC} Reconnecting $DEVICE_NAME...\n"

{
    bluetoothctl disconnect "$MAC_ADDRESS" > /dev/null 2>&1
    sleep 1
    if ! bluetoothctl connect "$MAC_ADDRESS" > /dev/null 2>&1; then
        printf "\n${RED}[Error]${NC} Failed to connect $DEVICE_NAME\n" > $(tty)
    fi
} &

exit 0
